#!/usr/bin/env bash
set -euo pipefail
umask 0022


#------------------------------------------------------------------------------
#
# git worktree helper
#
#
# The base directory for worktree is set in the .gitconfig file:
#
# ```
# [git-wt]
#     baseDir = ~/dev/worktrees
# ```
#
#------------------------------------------------------------------------------


usage() {
    cat << EOS
Usage: git wt <command> [args]

Commands:
    add <name>      Create a new worktree (creates branch if not exists)
    list, ls        List worktrees
    paths           List worktree paths
    remove, rm <name>  Remove a worktree
EOS
}

err() {
    echo "Error: $@" 1>&2
    exit 1
}

wt_base_dir_path() {
    local base_dir="$(git config --get git-wt.baseDir || true)"

    if [ -z "${base_dir}" ]; then
        if [ -n "${XDG_DATA_HOME}" ]; then
            base_dir="${XDG_DATA_HOME}/git-worktrees"
        else
            base_dir="${HOME}/.local/share/git-worktrees"
        fi
    fi

    # expand ~ if present (e.g. from gitconfig value)
    base_dir="${base_dir/#\~/$HOME}"
    echo "${base_dir}"
}

wt_project_path() {
    local wpath=""

    local origin_url=""
    if origin_url="$(git remote get-url origin 2>/dev/null)"; then
        local url="${origin_url%.git}"

        case "$url" in
            git@*)
                local host="$(printf '%s\n' "$url" | sed -E 's#git@([^:]+):.*#\1#')"
                local path="$(printf '%s\n' "$url" | sed -E 's#git@[^:]+:(.*)#\1#')"
                wpath="${host}/${path}"
                ;;

            http://*|https://*)
                local host="$(printf '%s\n' "$url" | sed -E 's#https?://([^/]+)/.*#\1#')"
                local path="$(printf '%s\n' "$url" | sed -E 's#https?://[^/]+/(.*)#\1#')"
                wpath="${host}/${path}"
                ;;

            *)
                ;;
        esac
    fi

    # fallback
    if [ -z "${wpath}" ]; then
        local repo_root="$(git rev-parse --show-toplevel)"
        local repo_name="$(basename "${repo_root}")"
        wpath="localhost/${repo_name}"
    fi

    echo "${wpath}"
}

main() {
    if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        err "not inside a git repository"
    fi

    local wt_dir="$(wt_base_dir_path)/$(wt_project_path)"

    local cmd="${1:-}"
    shift || true

    case "${cmd}" in
        add)
            local wt_name="${1:-}"
            if [ -z "${wt_name}" ]; then
                err "worktree name required"
            fi

            local wt_path="${wt_dir}/${wt_name}"

            if [ -e "${wt_path}" ]; then
                err "worktree already exists: ${wt_path}"
            fi

            mkdir -p "${wt_dir}"

            if git show-ref --verify --quiet "refs/heads/${wt_name}"; then
                git worktree add "${wt_path}" "${wt_name}"
            else
                git worktree add -b "${wt_name}" "${wt_path}"
            fi

            echo "Worktree created: ${wt_path}"
            ;;

        list|ls)
            git worktree list
            ;;

        paths)
            # "COMMIT_HASH [WORKTREE_NAME] WORKTREE_PATH"
            git worktree list | awk -v dir="${wt_dir}" 'index($1, dir) == 1 {print $2, $3, $1}'
            ;;

        remove|rm)
            local wt_name="${1:-}"
            if [ -z "${wt_name}" ]; then
                err "worktree name required"
            fi

            local wt_path="${wt_dir}/${wt_name}"

            if [ ! -e "${wt_path}" ]; then
                err "worktree not found: ${wt_path}"
            fi

            git worktree remove "${wt_path}"
            echo "Worktree removed: ${wt_path}"
            ;;

        ""|help|-h|--help)
            usage
            ;;

        *)
            echo "Unknown command: ${cmd}" 1>&2
            usage >&2
            exit 1
            ;;
    esac
}

main "$@"
